<UserControl x:Class="SistemaJuridico.Views.VerificacaoSteps.VerificacaoFinanceiraStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <GroupBox Header="Diligência" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <CheckBox Content="Diligência realizada" Margin="0,0,0,6" IsChecked="{Binding Parent.DiligenciaRealizada}"/>
                <TextBlock Text="Descrição da diligência" Margin="0,0,0,4"/>
                <TextBox AcceptsReturn="True" Height="70" Margin="0,0,0,6" TextWrapping="Wrap" Text="{Binding Parent.DescricaoDiligencia, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Prazo da diligência" Margin="0,0,0,4"/>
                <DatePicker SelectedDateFormat="Short" Text="{Binding Parent.PrazoDiligencia, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Pendências" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <CheckBox Content="Possui pendências" Margin="0,0,0,6" IsChecked="{Binding Parent.PossuiPendencias}"/>
                <TextBlock Text="Descrição das pendências" Margin="0,0,0,4"/>
                <TextBox AcceptsReturn="True" Height="70" TextWrapping="Wrap" Text="{Binding Parent.DescricaoPendencias, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
