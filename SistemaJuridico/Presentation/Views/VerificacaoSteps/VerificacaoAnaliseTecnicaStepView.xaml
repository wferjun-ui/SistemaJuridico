<UserControl x:Class="SistemaJuridico.Views.VerificacaoSteps.VerificacaoAnaliseTecnicaStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <GroupBox Header="Descrição da Verificação" Margin="0,0,0,10">
            <TextBox Margin="8"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     Text="{Binding Parent.Descricao, UpdateSourceTrigger=PropertyChanged}"/>
        </GroupBox>

        <GroupBox Header="Verificação de terapias e demais itens">
            <DataGrid Margin="8"
                      ItemsSource="{Binding Parent.ItensSaude}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo" Width="120" Binding="{Binding Tipo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Nome" Width="*" Binding="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Qtd" Width="95" Binding="{Binding Qtd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Necessidade" Width="120" IsReadOnly="True" Binding="{Binding NecessidadeTexto}"/>
                    <DataGridTextColumn Header="Frequência" Width="120" Binding="{Binding Frequencia, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Local" Width="150" Binding="{Binding Local, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Data Prescrição" Width="130" Binding="{Binding DataPrescricao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridCheckBoxColumn Header="Tratamento desnecessário" Width="170" Binding="{Binding IsDesnecessario, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridCheckBoxColumn Header="SUS" Width="70" Binding="{Binding IsSus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridCheckBoxColumn Header="Particular" Width="95" Binding="{Binding IsParticular, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </StackPanel>
</UserControl>
