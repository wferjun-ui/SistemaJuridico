<UserControl x:Class="SistemaJuridico.Views.ContasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="Prestação de Contas" FontSize="18" FontWeight="SemiBold"/>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Tipo de Prestação de Contas" FontWeight="SemiBold"/>
                        <ComboBox x:Name="TipoPrestacaoComboBox"
                                  ItemsSource="{Binding TiposPrestacaoDisponiveis}"
                                  SelectedItem="{Binding TipoSelecionado, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Border Margin="0,12,0,0" Visibility="{Binding ExibirCampos, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <WrapPanel>
                                <StackPanel Width="240" Margin="0,0,8,8"><TextBlock Text="Número do Processo *"/><TextBox Text="{Binding NumeroProcesso}"/></StackPanel>
                                <StackPanel Width="240" Margin="0,0,8,8"><TextBlock Text="Data da Prestação *"/><TextBox Text="{Binding DataPrestacao}"/></StackPanel>
                                <StackPanel Width="240" Margin="0,0,8,8"><TextBlock Text="Valor Total *"/><TextBox Text="{Binding ValorTotal}"/></StackPanel>
                                <StackPanel Width="240" Margin="0,0,8,8"><TextBlock Text="Responsável *"/><TextBox Text="{Binding Responsavel}"/></StackPanel>
                            </WrapPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Observações"/><TextBox Text="{Binding Observacoes}"/></StackPanel>

                            <Border Visibility="{Binding IsDiaria, Converter={StaticResource BoolToVis}}">
                                <WrapPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Data Início *"/><TextBox Text="{Binding DataInicio}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Data Fim *"/><TextBox Text="{Binding DataFim}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Destino *"/><TextBox Text="{Binding Destino}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Justificativa *"/><TextBox Text="{Binding Justificativa}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Valor por Dia"/><TextBox Text="{Binding ValorPorDia, StringFormat=N2}" IsReadOnly="True"/></StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Visibility="{Binding IsReembolso, Converter={StaticResource BoolToVis}}">
                                <WrapPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Nº Documento Fiscal *"/><TextBox Text="{Binding NumeroDocumentoFiscal}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Data Documento *"/><TextBox Text="{Binding DataDocumento}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="CNPJ Fornecedor *"/><TextBox Text="{Binding CnpjFornecedor}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Descrição Serviço *"/><TextBox Text="{Binding DescricaoServico}"/></StackPanel>
                                    <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Valor Documento *"/><TextBox Text="{Binding ValorDocumento}"/></StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Visibility="{Binding IsConvenio, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <WrapPanel>
                                        <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Número do Convênio *"/><TextBox Text="{Binding NumeroConvenio}"/></StackPanel>
                                        <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Órgão Repassador *"/><TextBox Text="{Binding OrgaoRepassador}"/></StackPanel>
                                        <StackPanel Width="230" Margin="0,0,8,8"><TextBlock Text="Período de Execução *"/><TextBox Text="{Binding PeriodoExecucao}"/></StackPanel>
                                    </WrapPanel>
                                    <TextBlock Text="Relatório detalhado *"/>
                                    <TextBox Text="{Binding RelatorioDetalhado}" AcceptsReturn="True" Height="70"/>
                                </StackPanel>
                            </Border>

                            <Border Visibility="{Binding IsOutro, Converter={StaticResource BoolToVis}}">
                                <StackPanel><TextBlock Text="Descrição detalhada *"/><TextBox Text="{Binding DetalhesOutroTipo}"/></StackPanel>
                            </Border>

                            <TextBlock Text="Anexos" Margin="0,8,0,0" FontWeight="SemiBold"/>
                            <WrapPanel>
                                <TextBox Width="400" Text="{Binding NovoAnexo}"/>
                                <Button Content="Adicionar Anexo" Command="{Binding AdicionarAnexoCommand}" Margin="8,0,0,0"/>
                            </WrapPanel>
                            <ItemsControl ItemsSource="{Binding Anexos}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <WrapPanel Margin="0,4,0,0">
                                            <TextBlock Text="{Binding}" Width="380"/>
                                            <Button Content="Remover"
                                                    Command="{Binding DataContext.RemoverAnexoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="Salvar Rascunho" Command="{Binding SalvarRascunhoCommand}" Margin="0,0,8,0"/>
                        <Button Content="Finalizar Prestação" Command="{Binding FinalizarPrestacaoCommand}" Margin="0,0,8,0"/>
                        <Button Content="Gerar PDF" Command="{Binding GerarPdfCommand}" IsEnabled="{Binding GerarPdfHabilitado}"/>
                        <Border Background="{Binding StatusCor}" CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
                            <TextBlock Foreground="White" Text="{Binding StatusDescricao}"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <GroupBox Header="Histórico da Conta" Margin="0,12,0,0">
                <DataGrid x:Name="HistoricoDataGrid" ItemsSource="{Binding Historico}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataFormatada}" Width="160"/>
                        <DataGridTextColumn Header="Usuário" Binding="{Binding Usuario}" Width="180"/>
                        <DataGridTextColumn Header="Ação" Binding="{Binding Acao}" Width="190"/>
                        <DataGridTextColumn Header="Descrição detalhada" Binding="{Binding Observacao}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Prestações já realizadas" Margin="0,12,0,0">
                <StackPanel>
                    <DataGrid ItemsSource="{Binding PrestacoesRealizadas}" SelectedItem="{Binding PrestacaoSelecionada}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data" Binding="{Binding DataMovimentacao}" Width="140"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoLancamento}" Width="140"/>
                            <DataGridTextColumn Header="Valor Total" Binding="{Binding ValorConta, StringFormat=R$ {0:N2}}" Width="130"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusConta}" Width="130"/>
                            <DataGridTextColumn Header="Última Modificação" Binding="{Binding UltimaModificacao}" Width="170"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="Carregar prestação selecionada" Command="{Binding CarregarPrestacaoSelecionadaCommand}" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
