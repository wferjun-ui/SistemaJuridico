<UserControl x:Class="SistemaJuridico.Views.VerificacoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="Control" x:Key="DefaultFieldStyle">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#DC2626"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="35*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="65*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="8">
            <DataGrid ItemsSource="{Binding Verificacoes}"
                      SelectedItem="{Binding VerificacaoSelecionada, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      RowHeight="32">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoVerificacao}" Width="*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                    <DataGridTextColumn Header="DataSolicitação" Binding="{Binding DataSolicitacao, StringFormat=dd/MM/yyyy}" Width="*"/>
                    <DataGridTextColumn Header="DataResposta" Binding="{Binding DataResposta, StringFormat=dd/MM/yyyy}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Tipo de Verificação"/>
                    <ComboBox Grid.Row="0" Grid.Column="2" Width="280"
                              Style="{StaticResource DefaultFieldStyle}"
                              ItemsSource="{Binding TiposVerificacao}"
                              SelectedItem="{Binding VerificacaoSelecionada.TipoVerificacao, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"/>

                    <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="Status"/>
                    <ComboBox Grid.Row="0" Grid.Column="6"
                              Style="{StaticResource DefaultFieldStyle}"
                              ItemsSource="{Binding StatusDisponiveis}"
                              SelectedItem="{Binding VerificacaoSelecionada.Status, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Data de Solicitação"/>
                    <DatePicker Grid.Row="2" Grid.Column="2" Width="150" Loaded="DatePicker_Loaded"
                                SelectedDate="{Binding VerificacaoSelecionada.DataSolicitacao, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"/>

                    <TextBlock Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Text="Data de Resposta"/>
                    <DatePicker Grid.Row="2" Grid.Column="6" Width="150" Loaded="DatePicker_Loaded"
                                SelectedDate="{Binding VerificacaoSelecionada.DataResposta, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Responsável"/>
                    <TextBox Grid.Row="4" Grid.Column="2" Width="220"
                             Style="{StaticResource DefaultFieldStyle}"
                             Text="{Binding VerificacaoSelecionada.Responsavel, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"/>

                    <TextBlock Grid.Row="4" Grid.Column="4" VerticalAlignment="Center" Text="Quantidade de Tratamentos"/>
                    <Grid Grid.Row="4" Grid.Column="6" Width="140" Height="32">
                        <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4"/>
                        <TextBox Margin="0" Padding="8,0,28,0" BorderThickness="0" VerticalContentAlignment="Center"
                                 PreviewTextInput="QuantidadeTextBox_PreviewTextInput"
                                 Text="{Binding VerificacaoSelecionada.QuantidadeTratamentos, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"/>
                        <Grid HorizontalAlignment="Right" Width="20" Margin="0,0,4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Width="16" Height="16" FontSize="9" Content="▲" Padding="0"
                                    Command="{Binding IncrementarQuantidadeTratamentosCommand}"/>
                            <Button Grid.Row="1" Width="16" Height="16" FontSize="9" Content="▼" Padding="0"
                                    Command="{Binding DecrementarQuantidadeTratamentosCommand}"/>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" Text="Resultado"/>
                    <TextBox Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="5" Height="60"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Text="{Binding VerificacaoSelecionada.Resultado, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Top" Text="Observações"/>
                    <TextBox Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="5" Height="90"
                             AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Text="{Binding VerificacaoSelecionada.Observacoes, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Adicionar" Width="100" Height="30" Margin="0,0,8,0" Command="{Binding AdicionarVerificacaoCommand}" IsEnabled="{Binding PodeAdicionar}"/>
                    <Button Content="Salvar" Width="100" Height="30" Margin="0,0,8,0" Command="{Binding SalvarVerificacaoCommand}" IsEnabled="{Binding PodeSalvar}"/>
                    <Button Content="Remover" Width="100" Height="30" Margin="0,0,8,0" Command="{Binding RemoveVerificacaoCommand}" IsEnabled="{Binding PodeExcluir}"/>
                    <Button Content="Limpar" Width="100" Height="30" Command="{Binding LimparFormularioCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
